    flight_id INTEGER PRIMARY KEY,
    flight_number TEXT,
    airline TEXT,
    origin_airport TEXT,
    destination_airport TEXT,
    connection_airport TEXT,
    departure_time TEXT,
    arrival_time TEXT,
    delay_minutes INTEGER,
    status TEXT,
    flight_type TEXT,
    technical_stop_flag TEXT,
    technical_stop_note TEXT,
    connection_time INTEGER
);



